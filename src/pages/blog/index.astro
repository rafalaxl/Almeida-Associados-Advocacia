---
import Layout from '../../layouts/Layout.astro';

const schema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "Blog",
  "name": "Artigos e Teses Jurídicas | Almeida & Associados",
  "description": "Análises técnicas, artigos e pareceres sobre Direito Societário e Tributário."
});

const articles = [
  {
    title: "O Planejamento Sucessório via Holding e a Proteção Patrimonial",
    date: "10 de Junho, 2026",
    excerpt: "Como a criação de holdings familiares atua na preservação do patrimônio contra riscos operacionais e simplifica a sucessão de bens corporativos.",
    category: "Societário"
  },
  {
    title: "Principais Teses Tributárias para Recuperação de Crédito em 2026",
    date: "28 de Maio, 2026",
    excerpt: "Uma análise detalhada das decisões recentes dos tribunais superiores que abrem oportunidades legais de compensação tributária para empresas.",
    category: "Tributário"
  }
];
---

<Layout 
  title="Artigos e Pareceres | Almeida & Associados" 
  description="Acesse artigos informativos e pareceres técnicos sobre Direito Societário e Planejamento Tributário escritos por nossos sócios."
  schema={schema}
>
  <section class="bg-[var(--color-brand-600)] text-white py-16 px-6 md:px-12 text-center">
    <span class="font-sans text-xs uppercase tracking-[0.2em] text-[var(--color-highlight)] font-semibold mb-2 block">Conhecimento Técnico</span>
    <h1 class="font-serif text-3xl md:text-4xl font-bold">Artigos & Pareceres</h1>
  </section>

  <section class="py-16 px-6 md:px-12 max-w-4xl mx-auto">
    <div class="space-y-12">
      {articles.map(article => (
        <article class="border-b border-[var(--color-border)] pb-10">
          <div class="flex items-center space-x-3 mb-3">
            <span class="text-[10px] font-sans font-bold text-[var(--color-highlight)] uppercase tracking-wider">{article.category}</span>
            <span class="text-[10px] text-[var(--color-text-muted)]">•</span>
            <time class="text-[10px] font-sans text-[var(--color-text-muted)]">{article.date}</time>
          </div>
          <h2 class="font-serif text-xl font-bold text-[var(--color-accent)] hover:text-[var(--color-highlight)] transition-colors mb-3">
            <a href="#">{article.title}</a>
          </h2>
          <p class="font-sans text-sm text-[var(--color-text-secondary)] leading-relaxed mb-4">
            {article.excerpt}
          </p>
          <a href="#" class="font-sans text-xs font-semibold text-[var(--color-highlight)] hover:underline">
            Ler Parecer Completo →
          </a>
        </article>
      ))}
    </div>
  </section>
</Layout>
