---
import Layout from '../layouts/Layout.astro';

const schema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "ContactPage",
  "name": "Contato | Almeida & Associados",
  "description": "Agende uma consulta técnica com nossos advogados especialistas."
});
---

<Layout 
  title="Contato | Almeida & Associados" 
  description="Entre em contato com nossa banca de advocacia e agende sua consulta técnica tributária ou societária."
  schema={schema}
>
  <section class="bg-[var(--color-brand-600)] text-white py-16 px-6 md:px-12 text-center">
    <span class="font-sans text-xs uppercase tracking-[0.2em] text-[var(--color-highlight)] font-semibold mb-2 block">Canais de Atendimento</span>
    <h1 class="font-serif text-3xl md:text-4xl font-bold">Fale Conosco</h1>
  </section>

  <section class="py-16 px-6 md:px-12 max-w-4xl mx-auto grid grid-cols-1 md:grid-cols-2 gap-12">
    <div>
      <h2 class="font-serif text-2xl font-bold text-[var(--color-accent)] mb-4">Agende uma Reunião</h2>
      <p class="font-sans text-sm text-[var(--color-text-secondary)] leading-relaxed mb-6">
        Utilize o formulário ao lado para iniciar um atendimento técnico preliminar. Seus dados estarão resguardados sob sigilo profissional nos termos da LGPD.
      </p>
      <div class="space-y-4 font-sans text-xs text-[var(--color-text-secondary)]">
        <div>
          <span class="font-bold block text-[var(--color-accent)] mb-1">Endereço</span>
          Av. Paulista, 1000, 10º andar • Bela Vista, São Paulo/SP
        </div>
        <div>
          <span class="font-bold block text-[var(--color-accent)] mb-1">Canais Oficiais</span>
          Telefone: +55 (11) 3333-3333<br />
          E-mail: contato@almeidaeassociados.adv.br
        </div>
      </div>
    </div>

    <!-- Contact Form -->
    <form id="contact-form" class="bg-white border border-[var(--color-border)] p-6 space-y-4">
      <!-- Honeypot field (hidden from users, anti-spam) -->
      <div class="hidden">
        <label for="website">Website</label>
        <input type="text" id="website" name="website" tabindex="-1" autocomplete="off" />
      </div>

      <div>
        <label for="name" class="block font-sans text-xs font-semibold text-[var(--color-text-secondary)] mb-1">Nome Completo</label>
        <input type="text" id="name" required class="w-full font-sans text-sm border border-[var(--color-border)] p-2.5 rounded-[var(--radius-md)] focus:outline-none focus:ring-1 focus:ring-[var(--color-highlight)]" />
      </div>

      <div>
        <label for="email" class="block font-sans text-xs font-semibold text-[var(--color-text-secondary)] mb-1">E-mail Corporativo</label>
        <input type="email" id="email" required class="w-full font-sans text-sm border border-[var(--color-border)] p-2.5 rounded-[var(--radius-md)] focus:outline-none focus:ring-1 focus:ring-[var(--color-highlight)]" />
      </div>

      <div>
        <label for="phone" class="block font-sans text-xs font-semibold text-[var(--color-text-secondary)] mb-1">Telefone / WhatsApp</label>
        <input type="tel" id="phone" required placeholder="(11) 99999-9999" class="w-full font-sans text-sm border border-[var(--color-border)] p-2.5 rounded-[var(--radius-md)] focus:outline-none focus:ring-1 focus:ring-[var(--color-highlight)]" />
      </div>

      <div>
        <label for="message" class="block font-sans text-xs font-semibold text-[var(--color-text-secondary)] mb-1">Descrição Sumária da Demanda</label>
        <textarea id="message" required rows="3" class="w-full font-sans text-sm border border-[var(--color-border)] p-2.5 rounded-[var(--radius-md)] focus:outline-none focus:ring-1 focus:ring-[var(--color-highlight)]"></textarea>
      </div>

      <button type="submit" class="w-full bg-[var(--color-accent)] hover:bg-[var(--color-accent-hover)] text-white font-semibold text-xs py-3 uppercase tracking-wider rounded-[var(--radius-sm)] transition-colors">
        Enviar Mensagem e Contatar WhatsApp
      </button>
    </form>
  </section>
</Layout>

<script>
  // Dynamic Phone Mask & Validation
  const phoneInput = document.getElementById('phone') as HTMLInputElement;
  phoneInput?.addEventListener('input', (e) => {
    let x = (e.target as HTMLInputElement).value.replace(/\D/g, '');
    if (x.length > 11) x = x.substring(0, 11);
    
    if (x.length <= 2) {
      phoneInput.value = x;
    } else if (x.length <= 6) {
      phoneInput.value = `(${x.substring(0, 2)}) ${x.substring(2)}`;
    } else if (x.length <= 10) {
      phoneInput.value = `(${x.substring(0, 2)}) ${x.substring(2, 6)}-${x.substring(6)}`;
    } else {
      phoneInput.value = `(${x.substring(0, 2)}) ${x.substring(2, 7)}-${x.substring(7)}`;
    }
  });

  // Form Handling with Honeypot check and redirection
  const form = document.getElementById('contact-form') as HTMLFormElement;
  form?.addEventListener('submit', (e) => {
    e.preventDefault();
    const websiteHoneypot = (document.getElementById('website') as HTMLInputElement).value;
    if (websiteHoneypot) {
      console.warn("Spam detected");
      return;
    }

    const name = (document.getElementById('name') as HTMLInputElement).value;
    const email = (document.getElementById('email') as HTMLInputElement).value;
    const phone = phoneInput.value;
    const msg = (document.getElementById('message') as HTMLInputElement).value;

    // Sanitize input to prevent XSS / raw injection
    const cleanName = encodeURIComponent(name.replace(/[<>]/g, ''));
    const cleanMsg = encodeURIComponent(msg.replace(/[<>]/g, ''));

    const text = `Olá, meu nome é ${cleanName}. Gostaria de agendar uma consulta jurídica.\nE-mail: ${email}\nTelefone: ${phone}\nDemanda: ${cleanMsg}`;
    
    // Redirect to Corporate WhatsApp
    window.open(`https://api.whatsapp.com/send?phone=551133333333&text=${text}`, '_blank');
  });
</script>
