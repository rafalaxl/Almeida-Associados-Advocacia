---
const year = new Date().getFullYear();
---

<footer class="bg-[var(--color-accent)] text-[var(--color-text-inverse)] border-t border-[var(--color-border)] py-12 px-6 md:px-12">
  <div class="max-w-7xl mx-auto grid grid-cols-1 md:grid-cols-3 gap-8 mb-8">
    <div class="flex flex-col">
      <span class="font-serif text-lg font-bold tracking-wider text-white">ALMEIDA & ASSOCIADOS</span>
      <span class="font-sans text-[10px] uppercase tracking-[0.2em] text-[var(--color-highlight)] mb-4">Advocacia Corporativa</span>
      <p class="text-xs text-[var(--gray-300)] font-sans max-w-sm">
        Banca jurídica de boutique dedicada exclusivamente a soluções tributárias e societárias de alta complexidade.
      </p>
    </div>

    <div>
      <h3 class="font-serif text-sm font-semibold text-[var(--color-highlight)] uppercase tracking-wider mb-4">Contatos Rápidos</h3>
      <ul class="text-xs space-y-2 text-[var(--gray-300)] font-sans">
        <li>Telefone: +55 (11) 3333-3333</li>
        <li>E-mail: contato@almeidaeassociados.adv.br</li>
        <li>Av. Paulista, 1000, 10º andar - São Paulo/SP</li>
      </ul>
    </div>

    <div>
      <h3 class="font-serif text-sm font-semibold text-[var(--color-highlight)] uppercase tracking-wider mb-4">Informações Legais</h3>
      <p class="text-xs text-[var(--gray-300)] font-sans mb-2">
        Almeida & Associados Advocacia • OAB/SP nº 99.999
      </p>
      <p class="text-xs text-[var(--gray-300)] font-sans">
        CNPJ: 00.000.000/0001-00
      </p>
      <div class="flex space-x-4 mt-4 text-[var(--gray-400)] text-xs">
        <a href="/privacidade/" class="hover:text-[var(--color-highlight)] transition-colors">Política de Privacidade</a>
        <a href="/termos/" class="hover:text-[var(--color-highlight)] transition-colors">Termos de Uso</a>
      </div>
    </div>
  </div>

  <div class="max-w-7xl mx-auto pt-6 border-t border-[var(--gray-800)] flex flex-col md:flex-row items-center justify-between text-[11px] text-[var(--gray-400)] font-sans">
    <p>&copy; {year} Almeida & Associados. Todos os direitos reservados.</p>
    <p>Conforme normas da OAB e provimento 94/2000. Foco informativo e institucional.</p>
  </div>
</footer>
